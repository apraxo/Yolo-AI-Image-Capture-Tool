title DataCapture Pro - Auto Builder
echo.
echo  ============================================================
echo   DataCapture Pro - Auto Installer ^& Builder
echo  ============================================================
echo.
python --version >nul 2>&1
if errorlevel 1 (
    echo  [ERROR] Python not found. Install from https://www.python.org/downloads/
    echo  Tick "Add Python to PATH" during install, then re-run.
    pause & exit /b 1
)
for /f "tokens=2 delims= " %%V in ('python --version 2^>^&1') do set PYVER=%%V
echo  [OK] Found Python %PYVER%
echo.
echo  [1/3] Upgrading pip...
python -m pip install --upgrade pip --quiet
echo  [OK] pip ready
echo.
echo  [2/3] Installing dependencies...
echo.
for %%P in (mss pillow pynput opencv-python numpy onnxruntime pyinstaller) do (
    echo        Installing %%P ...
    python -m pip install %%P --quiet --disable-pip-version-check
    if errorlevel 1 ( echo  [ERROR] Failed: %%P & pause & exit /b 1 )
    echo  [OK]   %%P
)
echo.
echo        Installing ultralytics (enables .pt model support)...
python -m pip install ultralytics --quiet --disable-pip-version-check
if errorlevel 1 (
    echo  [WARN] ultralytics install failed - .pt models will use fallback loader
) else (
