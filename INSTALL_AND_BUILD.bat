@echo off
setlocal enabledelayedexpansion
title DataCapture Pro - Auto Installer ^& Builder
color 0B
echo.
echo  ============================================================
echo   DataCapture Pro - Fully Automatic Installer ^& Builder
echo  ============================================================
echo.
if "%~1"=="ELEVATED" goto :after_elev
net session >nul 2>&1
if %errorlevel% neq 0 (
    echo  [INFO] Requesting admin rights...
    powershell -Command "Start-Process -FilePath '%~f0' -ArgumentList 'ELEVATED' -WorkingDirectory '%~dp0' -Verb RunAs" >nul 2>&1
    if not errorlevel 1 exit /b 0
    echo  [WARN] No admin rights - continuing anyway.
)
:after_elev
echo  [1/6] Locating Python...
set "PYEXE="
python --version >nul 2>&1
if not errorlevel 1 ( set "PYEXE=python" & goto :py_found )
py -3 --version >nul 2>&1
if not errorlevel 1 ( set "PYEXE=py -3" & goto :py_found )
for %%D in (
    "%LocalAppData%\Programs\Python\Python312\python.exe"
    "%LocalAppData%\Programs\Python\Python311\python.exe"
    "%LocalAppData%\Programs\Python\Python310\python.exe"
    "%ProgramFiles%\Python312\python.exe"
    "%ProgramFiles%\Python311\python.exe"
    "%ProgramFiles%\Python310\python.exe"
    "C:\Python311\python.exe"
) do ( if exist %%D ( set "PYEXE=%%~D" & goto :py_found ) )
echo  [INFO] Python not found. Installing Python 3.11.9...
set "PYINST=%TEMP%\python_setup_dcp.exe"
where winget >nul 2>&1
if not errorlevel 1 (
    winget install -e --id Python.Python.3.11 --scope machine --silent --accept-source-agreements --accept-package-agreements >nul 2>&1
    if not errorlevel 1 goto :recheck
)
echo        Downloading Python...
where curl >nul 2>&1
if not errorlevel 1 ( curl -L -o "%PYINST%" "https://www.python.org/ftp/python/3.11.9/python-3.11.9-amd64.exe" ) else (
    powershell -Command "[Net.ServicePointManager]::SecurityProtocol=[Net.SecurityProtocolType]::Tls12; Invoke-WebRequest -Uri 'https://www.python.org/ftp/python/3.11.9/python-3.11.9-amd64.exe' -OutFile '%PYINST%'" >nul 2>&1 )
if not exist "%PYINST%" (
    echo  [ERROR] Download failed. Install Python from python.org ^(tick Add to PATH^) and re-run.
    pause & exit /b 1 )
echo        Installing Python silently...
"%PYINST%" /quiet InstallAllUsers=1 PrependPath=1 Include_test=0 Include_launcher=1 >nul 2>&1
del "%PYINST%" >nul 2>&1
:recheck
python --version >nul 2>&1
if not errorlevel 1 ( set "PYEXE=python" & goto :py_found )
py -3 --version >nul 2>&1
if not errorlevel 1 ( set "PYEXE=py -3" & goto :py_found )
for %%D in ("%ProgramFiles%\Python311\python.exe" "%LocalAppData%\Programs\Python\Python311\python.exe") do (
    if exist %%D ( set "PYEXE=%%~D" & goto :py_found ) )
echo  [ERROR] Python installed but not visible. CLOSE this window and run again.
pause & exit /b 1
:py_found
for /f "tokens=*" %%V in ('%PYEXE% --version 2^>^&1') do set "PYVERSTR=%%V"
echo  [OK] Using %PYVERSTR%
echo.
echo  [2/6] Detecting GPU...
set "GPUKIND=none"
where nvidia-smi >nul 2>&1
if not errorlevel 1 ( nvidia-smi >nul 2>&1
    if not errorlevel 1 ( set "GPUKIND=nvidia"
        for /f "tokens=*" %%G in ('nvidia-smi --query-gpu^=name --format^=csv^,noheader 2^>nul') do set "GPUNAME=%%G" ) )
if "!GPUKIND!"=="nvidia" ( echo  [OK] NVIDIA GPU: !GPUNAME! - installing CUDA runtimes ) else (
    echo  [INFO] No NVIDIA GPU - installing DirectML ^(AMD/Intel/NVIDIA^) )
echo.
echo  [3/6] Preparing pip...
%PYEXE% -m ensurepip --upgrade >nul 2>&1
%PYEXE% -m pip install --upgrade pip --quiet
echo  [OK] pip ready
echo.
echo  [4/6] Installing dependencies...
echo.
for %%P in (mss pillow pynput opencv-python numpy pyinstaller) do (
    echo        Installing %%P ...
    %PYEXE% -m pip install %%P --quiet --disable-pip-version-check
    if errorlevel 1 ( echo  [ERROR] Failed: %%P & pause & exit /b 1 )
    echo  [OK]   %%P )
echo.
echo        Removing any CPU-only onnxruntime...
%PYEXE% -m pip uninstall -y onnxruntime onnxruntime-gpu onnxruntime-directml >nul 2>&1
if "!GPUKIND!"=="nvidia" (
    echo        Installing onnxruntime-gpu ^(CUDA^)...
    %PYEXE% -m pip install onnxruntime-gpu --quiet --disable-pip-version-check
    if errorlevel 1 ( echo  [WARN] CUDA build failed - using DirectML
        %PYEXE% -m pip install onnxruntime-directml --quiet --disable-pip-version-check ) else ( echo  [OK]   onnxruntime-gpu )
) else (
    echo        Installing onnxruntime-directml...
    %PYEXE% -m pip install onnxruntime-directml --quiet --disable-pip-version-check
    if errorlevel 1 ( echo  [WARN] DirectML failed - using CPU onnxruntime
        %PYEXE% -m pip install onnxruntime --quiet --disable-pip-version-check ) else ( echo  [OK]   onnxruntime-directml ) )
echo.
if "!GPUKIND!"=="nvidia" (
    echo        Installing PyTorch with CUDA ^(large download^)...
    %PYEXE% -m pip install torch torchvision --index-url https://download.pytorch.org/whl/cu121 --quiet --disable-pip-version-check
    if errorlevel 1 ( echo  [WARN] CUDA torch failed - CPU torch
        %PYEXE% -m pip install torch torchvision --quiet --disable-pip-version-check ) else ( echo  [OK]   PyTorch ^(CUDA^) )
